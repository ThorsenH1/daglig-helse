rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin-sjekk: halvor.thorsenh1@gmail.com
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'halvor.thorsenh1@gmail.com';
    }
    
    // Brukere kan lese/skrive sine egne data
    // Admin kan lese ALLE brukeres data
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Alle sub-collections under brukeren (inkl. fcmTokens og _pushLog)
      match /{subcollection}/{document=**} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Blokker alt annet
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
