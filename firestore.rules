rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin-sjekk: halvor.thorsenh@gmail.com
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'halvor.thorsenh@gmail.com';
    }

    // Sjekk om innlogget bruker er venn av userId og har tillatelse for gitt subcollection
    function friendCanRead(userId, sub) {
      let f = get(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid));
      return f != null && f.data.permissions != null && (
        (sub == 'waterLogs'    && f.data.permissions.water    == true) ||
        (sub == 'medicineLogs' && f.data.permissions.medicine == true) ||
        (sub == 'medicines'    && f.data.permissions.medicine == true) ||
        (sub == 'bathroomLogs' && f.data.permissions.bathroom == true) ||
        (sub == 'healthLogs'   && f.data.permissions.health   == true) ||
        (sub == 'sleepLogs'    && f.data.permissions.sleep    == true) ||
        (sub == 'movementLogs' && f.data.permissions.movement == true) ||
        (sub == 'diaryLogs'    && f.data.permissions.diary    == true) ||
        (sub == 'checkins'     && f.data.permissions.checkin  == true)
      );
    }

    function isFriendOf(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid));
    }
    
    // Brukere kan lese/skrive sine egne data
    // Admin kan lese ALLE brukeres data
    // Venner kan lese brukerdokumentet (for settings som waterGoal)
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || isFriendOf(userId));
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Sub-collections: eier, admin, eller venn med relevant tillatelse
      match /{subcollection}/{document=**} {
        allow read: if request.auth != null && (
          request.auth.uid == userId || isAdmin() || friendCanRead(userId, subcollection)
        );
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Venner: vennen kan lese sin egen profil og opprette seg selv (ved aksept)
      match /friends/{friendUid} {
        allow read: if request.auth != null && (request.auth.uid == userId || request.auth.uid == friendUid || isAdmin());
        allow create: if request.auth != null && (request.auth.uid == userId || request.auth.uid == friendUid);
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Venneforespørsler: bruker kan lese/opprette sine egne
    match /friendRequests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid || resource.data.toEmail == request.auth.token.email);
      allow update: if request.auth != null
        && (resource.data.toEmail == request.auth.token.email || resource.data.fromUid == request.auth.uid);
      allow delete: if request.auth != null
        && (resource.data.fromUid == request.auth.uid || resource.data.toEmail == request.auth.token.email);
    }
    
    // Vennevarsler: venner kan opprette varsler til hverandre
    match /friendReminders/{reminderId} {
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow update: if false;
      allow delete: if request.auth != null
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }
    
    // Blokker alt annet
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
